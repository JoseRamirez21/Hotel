# ==========================================
# HOTELSYS - HOTEL LAS VEGAS
# Archivo de configuración
# ==========================================

APP_NAME="HotelSys"
APP_COMPANY="Hotel Las Vegas"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/hotel/public
APP_VERSION=1.0.0

TIMEZONE=America/Lima
LANGUAGE=es

# ==========================================
# BASE DE DATOS
# ==========================================

DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=hotel_las_vegas
DB_USERNAME=root
DB_PASSWORD=

# ==========================================
# MONEDA
# ==========================================

CURRENCY=S/

# ==========================================
# SESIONES
# ==========================================

SESSION_NAME=HOTELSYS
SESSION_LIFETIME=120

# ==========================================
# SUBIDAS
# ==========================================

MAX_UPLOAD_SIZE=5M
UPLOAD_FOLDER=public/assets/uploads